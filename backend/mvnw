# ----------------------------------------------------------------------------
# Maven Wrapper startup batch script, version 3.2.0
#
# Optional ENV vars
# -----------------
#   JAVA_HOME - location of a JDK home dir, the wrapper will use it if set
#   MAVEN_OPTS - parameters passed to the JVM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading settings.xml or .mavenrc
# ----------------------------------------------------------------------------

set -e

# OS specific support. $var _must_ be set to either true or false.
cygwin=false
darwin=false
os400=false
case "`uname`" in
  CYGWIN*) cygwin=true;;
  Darwin*) darwin=true;;
  OS400*) os400=true;;
esac

# ----------------------------------------------------------------------------
# Find executable
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=`pwd`
fi

while [ "$MAVEN_PROJECTBASEDIR" != "/" ] && [ ! -d "$MAVEN_PROJECTBASEDIR/.mvn" ]; do
  MAVEN_PROJECTBASEDIR=`dirname "$MAVEN_PROJECTBASEDIR"`
done

if [ ! -d "$MAVEN_PROJECTBASEDIR/.mvn" ]; then
  echo "Error: Could not find .mvn directory." >&2
  exit 1
fi

CLASSPATH=$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar

# ----------------------------------------------------------------------------
# Find Java
# ----------------------------------------------------------------------------

if [ -n "$JAVA_HOME" ] ; then
  if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
    # IBM's JDK on AIX uses strange locations for the executables
    JAVACMD="$JAVA_HOME/jre/sh/java"
  else
    JAVACMD="$JAVA_HOME/bin/java"
  fi
  if [ ! -x "$JAVACMD" ] ; then
    echo "Error: JAVA_HOME is set to an invalid directory." >&2
    echo "Please set the JAVA_HOME variable in your environment to match the" >&2
    echo "location of your Java installation." >&2
    exit 1
  fi
else
  JAVACMD="java"
  which java >/dev/null 2>&1 || exit 1
fi

# ----------------------------------------------------------------------------
# Run Maven
# ----------------------------------------------------------------------------

exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$CLASSPATH" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
